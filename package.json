{
  "name": "sqlite-simplifier",
  "version": "1.0.0",
  "description": "A simple and easy-to-use wrapper around react-native-sqlite-storage for React Native applications.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "react-native": "src/index.ts",
  "types": "lib/typescript/index.d.ts",
  "files": [
    "src",
    "lib",
    "README.md"
  ],
  "scripts": {
    "prepare": "bob build",
    "build": "bob build",
    "clean": "rimraf lib",
    "watch": "bob build --watch"
  },
  "keywords": [
    "sqlite",
    "database",
    "react-native",
    "sqlite-simplifier"
  ],
  "author": "Shadab Hussain",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-sqlite-storage": "*"
  },
  "devDependencies": {
    "@react-native-community/bob": "^0.17.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "react-native-sqlite-storage": "^6.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.1.0"
  },
  "@react-native-community/bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
