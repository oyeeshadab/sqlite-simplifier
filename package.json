{
  "name": "sqlite-simplifier",
  "version": "1.0.2",
  "description": "A type-safe and developer-friendly SQLite query builder and wrapper for React Native applications using react-native-sqlite-storage.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "react-native": "src/index.ts",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "bob build",
    "build": "bob build",
    "clean": "rimraf lib",
    "watch": "bob build --watch",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "react-native",
    "react-native-sqlite-storage",
    "sqlite",
    "sqlite3",
    "database",
    "query-builder",
    "offline-first",
    "storage",
    "local-database",
    "typescript",
    "sql",
    "orm",
    "react-native-database",
    "mobile-database",
    "fluent-api",
    "sqlite-wrapper",
    "sqlite-helper",
    "sqlite-simplifier"
  ],
  "author": "Shadab Hussain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oyeeshadab/sqlite-simplifier.git"
  },
  "homepage": "https://github.com/oyeeshadab/sqlite-simplifier#readme",
  "bugs": {
    "url": "https://github.com/oyeeshadab/sqlite-simplifier/issues"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-sqlite-storage": "*"
  },
  "devDependencies": {
    "@react-native-community/bob": "^0.17.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "react-native-sqlite-storage": "^6.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.1.0"
  },
  "engines": {
    "node": ">=16"
  },
  "sideEffects": false,
  "@react-native-community/bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
